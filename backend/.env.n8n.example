N8N_HOST=localhost
N8N_PORT=5678
N8N_PROTOCOL=http
N8N_EDITOR_BASE_URL=http://localhost:5678
WEBHOOK_URL=http://localhost:5678
N8N_ENFORCE_SETTINGS_FILE_PERMISSIONS=true

# Local service endpoints commonly used when recreating credentials
MONGODB_URL=mongodb://mongo:27017
MONGODB_DATABASE=nextgen
QDRANT_URL=http://qdrant:6333

# WhatsApp bridge target selection
N8N_TARGET=local
N8N_WA_MODE=production
WEBHOOK_URL_LOCAL=http://localhost:5678
WEBHOOK_URL_CLOUD=https://nextgen-n8n.westeurope.cloudapp.azure.com
WEBHOOK_URL_TAILNET=http://localhost:5678

# Optional convenience settings for the bridge
WA_PHONE=
WA_AUTH_PATH=./wa-auth
